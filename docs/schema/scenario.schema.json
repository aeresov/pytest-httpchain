              "description": "Form data to be URL-encoded.",
              "title": "Form",
              "type": "object"
            }
          },
          "required": [
            "form"
          ],
          "type": "object"
        }
      ],
      "title": "FormBody"
    },
    "FunctionsSubstitution": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
