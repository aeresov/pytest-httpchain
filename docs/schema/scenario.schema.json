            "functions"
          ],
          "type": "object"
        }
      ],
      "title": "FunctionsSubstitution"
    },
    "GraphQL": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "query": {
              "description": "GraphQL query string.",
              "examples": [
                "query { user { id name } }",
                "{{ graphql_query }}"
              ],
              "title": "Query",
              "type": "string"
            },
            "variables": {
              "anyOf": [
                {
                  "additionalProperties": {
                    "$ref": "#/$defs/JsonValue"
                  },
                  "type": "object"
                },
                {
                  "type": "string"
                }
              ],
              "description": "GraphQL query variables.",
              "title": "Variables"
            }
          },
          "required": [
            "query"
          ],
          "type": "object"
        }
      ],
      "title": "GraphQL"
    },
    "GraphQLBody": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "graphql": {
              "$ref": "#/$defs/GraphQL",
              "description": "GraphQL query configuration."
            }
          },
          "required": [
            "graphql"
          ],
          "type": "object"
        }
      ],
      "title": "GraphQLBody"
    },
    "HTTPMethod": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "enum": [
            "CONNECT",
            "DELETE",
            "GET",
            "HEAD",
            "OPTIONS",
            "PATCH",
            "POST",
            "PUT",
            "TRACE"
          ],
          "type": "string"
        }
      ],
      "title": "HTTPMethod",
      "description": "HTTP methods and descriptions\n\nMethods from the following RFCs are all observed:\n\n    * RFC 9110: HTTP Semantics, obsoletes 7231, which obsoleted 2616\n    * RFC 5789: PATCH Method for HTTP"
    },
    "HTTPStatus": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "enum": [
            100,
            101,
            102,
            103,
            200,
            201,
            202,
            203,
            204,
            205,
            206,
            207,
            208,
            226,
            300,
            301,
            302,
            303,
            304,
            305,
            307,
            308,
            400,
            401,
            402,
            403,
            404,
            405,
            406,
            407,
            408,
            409,
            410,
            411,
            412,
            413,
            413,
            414,
            414,
            415,
            416,
            416,
            417,
            418,
            421,
            422,
            422,
            423,
            424,
            425,
            426,
            428,
            429,
            431,
            451,
            500,
            501,
            502,
            503,
            504,
            505,
            506,
            507,
            508,
            510,
            511
          ],
          "type": "integer"
        }
      ],
      "title": "HTTPStatus",
      "description": "HTTP status codes and reason phrases\n\nStatus codes from the following RFCs are all observed:\n\n    * RFC 9110: HTTP Semantics, obsoletes 7231, which obsoleted 2616\n    * RFC 6585: Additional HTTP Status Codes\n    * RFC 3229: Delta encoding in HTTP\n    * RFC 4918: HTTP Extensions for WebDAV, obsoletes 2518\n    * RFC 5842: Binding Extensions to WebDAV\n    * RFC 7238: Permanent Redirect\n    * RFC 2295: Transparent Content Negotiation in HTTP\n    * RFC 2774: An HTTP Extension Framework\n    * RFC 7725: An HTTP Status Code to Report Legal Obstacles\n    * RFC 7540: Hypertext Transfer Protocol Version 2 (HTTP/2)\n    * RFC 2324: Hyper Text Coffee Pot Control Protocol (HTCPCP/1.0)\n    * RFC 8297: An HTTP Status Code for Indicating Hints\n    * RFC 8470: Using Early Data in HTTP"
    },
    "IndividualParameter": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "individual": {
              "additionalProperties": {
                "anyOf": [
                  {
                    "items": {},
                    "minItems": 1,
                    "type": "array"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "description": "Parameter name mapped to list of values (single parameter per step, non-empty values) or template expression",
              "maxProperties": 1,
              "minProperties": 1,
              "title": "Individual",
              "type": "object"
            },
            "ids": {
              "anyOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Optional IDs for each value",
              "title": "Ids"
            }
          },
          "required": [
            "individual"
          ],
          "type": "object"
        }
      ],
      "title": "IndividualParameter"
    },
    "JMESPathSave": {
