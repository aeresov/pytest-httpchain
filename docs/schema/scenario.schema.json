              "additionalProperties": {
                "type": "string"
              },
              "description": "JMESPath expressions to extract values from response.",
              "title": "Jmespath",
              "type": "object"
            }
          },
          "required": [
            "jmespath"
          ],
          "type": "object"
        }
      ],
      "title": "JMESPathSave",
      "description": "Save data using JMESPath expressions to extract values from response."
    },
