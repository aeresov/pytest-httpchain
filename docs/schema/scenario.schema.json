          "required": [
            "json"
          ],
          "type": "object"
        }
      ],
      "title": "JsonBody"
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {}
      ]
    },
    "ParallelForeachConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "max_concurrency": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "default": 10,
              "description": "Maximum number of concurrent requests.",
              "title": "Max Concurrency"
            },
            "calls_per_sec": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Maximum number of API calls per second. When set, requests are rate-limited globally across all workers.",
              "title": "Calls Per Sec"
            },
            "max_rate_limit_delay": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "default": 60,
              "description": "Maximum seconds to wait when rate-limited before giving up. Defaults to 60 seconds.",
              "title": "Max Rate Limit Delay"
            },
            "foreach": {
              "description": "Execute request once for each parameter set in parallel.",
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/IndividualParameter"
                  },
                  {
                    "$ref": "#/$defs/CombinationsParameter"
                  }
                ]
              },
              "title": "Foreach",
              "type": "array"
            }
          },
          "required": [
            "foreach"
          ],
          "type": "object"
        }
      ],
      "title": "ParallelForeachConfig",
      "description": "Execute request once for each parameter set in parallel."
    },
    "ParallelRepeatConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "max_concurrency": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "default": 10,
              "description": "Maximum number of concurrent requests.",
              "title": "Max Concurrency"
            },
            "calls_per_sec": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Maximum number of API calls per second. When set, requests are rate-limited globally across all workers.",
              "title": "Calls Per Sec"
            },
            "max_rate_limit_delay": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "default": 60,
              "description": "Maximum seconds to wait when rate-limited before giving up. Defaults to 60 seconds.",
              "title": "Max Rate Limit Delay"
            },
            "repeat": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "description": "Execute the same request N times in parallel.",
              "title": "Repeat"
            }
          },
          "required": [
            "repeat"
          ],
          "type": "object"
        }
      ],
      "title": "ParallelRepeatConfig",
      "description": "Execute the same request N times in parallel."
    },
    "Request": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "auth": {
              "anyOf": [
                {
                  "$ref": "#/$defs/UserFunctionName"
                },
                {
                  "$ref": "#/$defs/UserFunctionKwargs"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "User function to create custom authentication.",
              "title": "Auth"
            },
            "url": {
              "anyOf": [
                {
                  "format": "uri",
                  "maxLength": 2083,
                  "minLength": 1,
                  "type": "string"
                },
                {
                  "type": "string"
                }
              ],
              "description": "Request URL (may be a template expression).",
              "title": "Url"
            },
            "method": {
              "anyOf": [
                {
                  "$ref": "#/$defs/HTTPMethod"
                },
                {
                  "type": "string"
                }
              ],
              "default": "GET",
              "description": "HTTP method.",
              "title": "Method"
            },
            "params": {
              "additionalProperties": true,
              "description": "URL query parameters.",
              "title": "Params",
              "type": "object"
            },
            "headers": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "HTTP request headers.",
              "title": "Headers",
              "type": "object"
            },
            "body": {
              "anyOf": [
                {
                  "anyOf": [
                    {
                      "$ref": "#/$defs/JsonBody"
                    },
                    {
                      "$ref": "#/$defs/XmlBody"
                    },
                    {
                      "$ref": "#/$defs/FormBody"
                    },
                    {
                      "$ref": "#/$defs/TextBody"
                    },
                    {
                      "$ref": "#/$defs/Base64Body"
                    },
                    {
                      "$ref": "#/$defs/BinaryBody"
                    },
                    {
                      "$ref": "#/$defs/FilesBody"
                    },
                    {
                      "$ref": "#/$defs/GraphQLBody"
                    }
                  ]
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Request body configuration.",
              "title": "Body"
            },
            "timeout": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                {
                  "type": "string"
                }
              ],
              "default": 30.0,
              "description": "Request timeout in seconds.",
              "title": "Timeout"
            },
            "allow_redirects": {
              "anyOf": [
                {
                  "enum": [
                    true,
                    false
                  ],
                  "type": "boolean"
                },
                {
                  "type": "string"
                }
              ],
              "default": true,
              "description": "Whether to follow redirects.",
              "title": "Allow Redirects"
            }
          },
          "required": [
            "url"
          ],
          "type": "object"
        }
      ],
      "title": "Request"
    },
    "ResponseBody": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "schema": {
              "anyOf": [
                {
                  "additionalProperties": true,
                  "type": "object"
                },
                {
                  "format": "path",
                  "type": "string"
                },
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "JSON schema for validation.",
              "title": "Schema"
            },
            "contains": {
              "description": "Substrings the response body must contain.",
              "items": {
                "type": "string"
              },
              "title": "Contains",
              "type": "array"
            },
            "not_contains": {
              "description": "Substrings the response body must NOT contain.",
              "items": {
                "type": "string"
              },
              "title": "Not Contains",
              "type": "array"
            },
            "matches": {
              "description": "Regex patterns the response body must match.",
              "items": {
                "type": "string"
              },
              "title": "Matches",
              "type": "array"
            },
            "not_matches": {
              "description": "Regex patterns the response body must NOT match.",
              "items": {
                "type": "string"
              },
              "title": "Not Matches",
              "type": "array"
            }
          },
          "type": "object"
        }
      ],
      "title": "ResponseBody"
    },
    "SSLConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "verify": {
              "anyOf": [
                {
                  "enum": [
                    true,
                    false
                  ],
                  "type": "boolean"
                },
                {
                  "format": "path",
                  "type": "string"
                },
                {
                  "type": "string"
                }
              ],
              "default": true,
              "description": "SSL certificate verification. True (verify), False (no verification), or path to CA bundle.",
              "examples": [
                false,
                "/path/to/ca-bundle.crt",
                "{{ verify_ssl }}"
              ],
              "title": "Verify"
            },
            "cert": {
              "anyOf": [
                {
                  "maxItems": 2,
                  "minItems": 2,
                  "prefixItems": [
                    {
                      "anyOf": [
                        {
                          "format": "path",
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    {
                      "anyOf": [
                        {
                          "format": "path",
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  ],
                  "type": "array"
                },
                {
                  "format": "path",
                  "type": "string"
                },
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "SSL client certificate. Single file path or tuple of (cert_path, key_path).",
              "examples": [
                [
                  "/path/to/client.crt",
                  "/path/to/client.key"
                ],
                [
                  "/path/to/{{ client_cert_name }}",
                  "/path/to/client.key"
                ],
                "/path/to/client.pem",
                "/path/to/{{ cert_file_name }}"
              ],
              "title": "Cert"
            }
          },
          "type": "object"
        }
      ],
      "title": "SSLConfig"
    },
    "SaveStep": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "save": {
              "description": "Save configuration.",
              "title": "Save",
              "anyOf": [
                {
                  "$ref": "#/$defs/JMESPathSave"
                },
                {
                  "$ref": "#/$defs/SubstitutionsSave"
                },
                {
                  "$ref": "#/$defs/UserFunctionsSave"
                }
              ]
            }
          },
          "required": [
            "save"
          ],
          "type": "object"
        }
      ],
      "title": "SaveStep",
      "description": "Save data from HTTP response."
    },
    "Stage": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonRef"
        },
        {
          "additionalProperties": false,
          "properties": {
            "description": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Optional description for this component",
              "title": "Description"
            },
            "fixtures": {
              "description": "pytest fixtures",
              "items": {
                "type": "string"
              },
              "title": "Fixtures",
              "type": "array"
            },
            "marks": {
              "description": "pytest markers",
              "examples": [
                [
                  "xfail"
                ],
                [
                  "skip",
                  "slow"
                ]
              ],
              "items": {
                "type": "string"
              },
              "title": "Marks",
              "type": "array"
            },
            "name": {
              "default": "",
              "description": "Stage name (human-readable).",
              "title": "Name",
              "type": "string"
            },
            "substitutions": {
              "anyOf": [
                {
                  "items": {
                    "anyOf": [
                      {
                        "$ref": "#/$defs/VarsSubstitution"
                      },
                      {
                        "$ref": "#/$defs/FunctionsSubstitution"
                      }
                    ]
                  },
                  "type": "array"
                },
                {
                  "additionalProperties": {
                    "anyOf": [
                      {
                        "anyOf": [
                          {
                            "$ref": "#/$defs/VarsSubstitution"
                          },
                          {
                            "$ref": "#/$defs/FunctionsSubstitution"
                          }
                        ]
                      },
                      {
                        "items": {
                          "anyOf": [
                            {
                              "$ref": "#/$defs/VarsSubstitution"
                            },
                            {
                              "$ref": "#/$defs/FunctionsSubstitution"
                            }
                          ]
                        },
                        "type": "array"
                      }
                    ]
                  },
                  "type": "object"
                }
              ],
              "description": "Variable substitution configuration.",
              "title": "Substitutions"
            },
            "always_run": {
              "anyOf": [
                {
                  "enum": [
                    true,
                    false
                  ],
                  "type": "boolean"
                },
                {
                  "type": "string"
                }
              ],
              "default": false,
              "description": "Execute even if a previous stage failed. A template expression is evaluated (truthiness) when the chain is aborted, against fixtures, parametrize parameters, scenario substitutions, and previously saved variables.",
              "examples": [
                true,
                "{{ should_run }}",
                "{{ env == 'production' }}"
              ],
              "title": "Always Run"
            },
            "parametrize": {
              "anyOf": [
