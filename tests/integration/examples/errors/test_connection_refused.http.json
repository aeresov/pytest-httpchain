{
    "description": "Test connection refused error when server is not running",
    "stages": [
        {
            "name": "connection_refused",
            "description": "Request to a just-released (closed) port must be refused",
            "request": {
                "url": "http://127.0.0.1:{{ closed_port }}/nonexistent",
                "timeout": 2
            },
            "response": [
                {
                    "verify": {
                        "status": 200
                    }
                }
            ],
            "fixtures": [
                "closed_port"
            ]
        }
    ]
}
