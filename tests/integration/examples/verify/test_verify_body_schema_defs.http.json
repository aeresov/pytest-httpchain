{
    "stages": [
        {
            "name": "inline_schema_with_defs_passes",
            "description": "Inline schema using standard JSON Schema $defs/$ref survives loading and validates the body",
            "fixtures": ["server"],
            "request": {
                "url": "{{ server }}/schema-test"
            },
            "response": [
                {
                    "verify": {
                        "status": 200,
                        "body": {
                            "schema": {
                                "$ref": "#/$defs/user",
                                "$defs": {
                                    "user": {
                                        "type": "object",
                                        "required": ["id", "name"],
                                        "properties": {
                                            "id": { "type": "integer", "minimum": 1 },
                                            "name": { "type": "string", "minLength": 1 }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        },
        {
            "name": "inline_schema_ref_is_enforced",
            "description": "The schema-internal $ref is genuinely applied: a def the body cannot satisfy fails the verify",
            "fixtures": ["server"],
            "request": {
                "url": "{{ server }}/schema-test"
            },
            "response": [
                {
                    "verify": {
                        "status": 200,
                        "body": {
                            "schema": {
                                "$ref": "#/$defs/strict_user",
                                "$defs": {
                                    "strict_user": {
                                        "type": "object",
                                        "required": ["id", "name", "email"]
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        }
    ]
}
